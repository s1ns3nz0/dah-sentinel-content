{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspace": {
            "type": "String"
        }
    },
    "resources": [
        {
            "type": "Microsoft.OperationalInsights/workspaces/providers/watchlists",
            "name": "[concat(parameters('workspace'), '/Microsoft.SecurityInsights/C2_Whitelisted_GCS_List')]",
            "apiVersion": "2023-12-01-preview",
            "kind": "",
            "properties": {
                "displayName": "C2_Whitelisted_GCS_List",
                "source": "C2_Whitelisted_GCS_List.csv",
                "description": "S2 C2 Hijacking detection. Whitelist of valid command source SystemIds for MPD-001. 1=vehicle(SITL), 255=GCS. Commands from other SystemIds are flagged as unauthorized.",
                "provider": "DAH-BlueTeam",
                "isDeleted": false,
                "labels": [],
                "defaultDuration": "P1000Y",
                "contentType": "Text/Csv",
                "numberOfLinesToSkip": 0,
                "itemsSearchKey": "UAVId_s",
                "rawContent": "UAVId_s,SystemId_d,GCSName_s,Description_s,ValidationDate_t\r\nMPD-001,1,Vehicle-SITL,Vehicle self-originated (SITL auto-flight),2026-06-21\r\nMPD-001,255,QGroundControl-Primary,Primary GCS (sim gcs-qgc),2026-06-21\r\n"
            }
        }
    ]
}